{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Network Address Plan",
  "type": "object",
  "required": ["clouds", "root_range", "environments"],
  "properties": {
    "clouds": { "type": "array", "items": { "type": "string" } },
    "root_range": { "type": "string" },
    "reserved_ranges": { "type": "array", "items": { "type": "string" } },
    "environments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["environment", "cidr", "tiers"],
        "properties": {
          "environment": { "type": "string" },
          "cidr": { "type": "string" },
          "tiers": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["tier", "cidr", "subnets"],
              "properties": {
                "tier": { "type": "string" },
                "cidr": { "type": "string" },
                "subnets": { "type": "array" }
              }
            }
          }
        }
      }
    }
  }
}
